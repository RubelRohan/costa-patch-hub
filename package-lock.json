const express = require('express');
const sqlite3 = require('sqlite3').verbose();
const multer = require('multer');
const path = require('path');
const fs = require('fs');
const bcrypt = require('bcrypt');
const cors = require('cors');

const app = express();
const PORT = process.env.PORT || 3000;

// ====================== MIDDLEWARE ======================
app.use(cors());
app.use(express.json());
app.use('/uploads', express.static('uploads'));

// Create necessary folders
if (!fs.existsSync('uploads')) fs.mkdirSync('uploads', { recursive: true });
if (!fs.existsSync('backups')) fs.mkdirSync('backups', { recursive: true });

// Multer config
const upload = multer({ 
  dest: 'uploads/',
  limits: { fileSize: 5 * 1024 * 1024 },
  fileFilter: (req, file, cb) => {
    if (file.mimetype.startsWith('image/')) cb(null, true);
    else cb(new Error('Only images allowed'), false);
  }
});

// ====================== DATABASE ======================
const db = new sqlite3.Database('costa_patch.db');

// ====================== AUTOMATED BACKUP SYSTEM ======================
function createBackup() {
  const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);
  const backupFile = `backups/costa_patch_${timestamp}.db`;
  
  fs.copyFile('costa_patch.db', backupFile, (err) => {
    if (err) {
      console.error('❌ Backup failed:', err);
    } else {
      console.log(`✅ Backup created: ${backupFile}`);
      
      // Keep only last 7 backups (cleanup old ones)
      cleanupOldBackups();
    }
  });
}

function cleanupOldBackups() {
  fs.readdir('backups', (err, files) => {
    if (err) return;
    
    const backupFiles = files
      .filter(f => f.startsWith('costa_patch_'))
      .sort()
      .reverse();

    // Keep only 7 most recent backups
    backupFiles.slice(7).forEach(file => {
      fs.unlink(path.join('backups', file), () => {});
    });
  });
}

// Create backup on server start
createBackup();

// Auto backup every 24 hours
setInterval(() => {
  createBackup();
}, 24 * 60 * 60 * 1000); // 24 hours

// ====================== ERROR HANDLER ======================
const errorHandler = (err, req, res, next) => {
  console.error('❌ Error:', err);
  res.status(500).json({
    success: false,
    message: 'Internal Server Error',
    error: process.env.NODE_ENV === 'development' ? err.message : undefined
  });
};

// ====================== ROUTES ======================
// (All your previous routes - shortened for space)

app.get('/', (req, res) => res.send('✅ Costa MK Patch Hub API is running with Auto Backup!'));

app.get('/stores', (req, res, next) => {
  db.all("SELECT * FROM stores ORDER BY id", (err, rows) => { if (err) return next(err); res.json(rows); });
});

app.post('/stores', (req, res, next) => { /* ... */ });
app.put('/stores/:id', (req, res, next) => { /* ... */ });
app.delete('/stores/:id', (req, res, next) => { /* ... */ });

app.post('/login', async (req, res, next) => { /* ... */ });
app.post('/change-password', async (req, res, next) => { /* ... */ });

app.post('/entry', upload.single('photo'), (req, res, next) => { /* ... */ });

app.get('/entries', (req, res, next) => { /* ... */ });

// Manual Backup Route (Useful for Admin)
app.post('/backup', (req, res) => {
  createBackup();
  res.json({ success: true, message: "Manual backup triggered" });
});

// ====================== GLOBAL ERROR HANDLER ======================
app.use(errorHandler);

app.use((req, res) => {
  res.status(404).json({ success: false, message: 'Route not found' });
});

// ====================== START SERVER ======================
app.listen(PORT, () => {
  console.log(`🚀 Costa MK Patch Hub running at http://localhost:${PORT}`);
  console.log(`📁 Database: costa_patch.db`);
  console.log(`💾 Auto Backups: Enabled (Daily + on startup)`);
  console.log(`📂 Backups folder: /backups (last 7 kept)`);
});
